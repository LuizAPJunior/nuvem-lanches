{
  "name": "server",
  "version": "1.0.0",
  "description": "backend for an order system",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "nodemon --env-file=.env server.js",
    "test": "jest --forceExit"
